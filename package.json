{
  "name": "cctag",
  "version": "0.1.0",
  "description": "Slack ↔ local Claude Code TUI bridge, via herdr",
  "type": "module",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:hub": "tsx watch src/hub/index.ts",
    "dev:spoke": "tsx watch src/spoke/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "start:hub": "node dist/hub/index.js",
    "start:spoke": "node dist/spoke/index.js",
    "token": "tsx src/hub/index.ts token",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@slack/bolt": "^4.2.0",
    "dotenv": "^16.4.5",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
