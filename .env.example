# Slack app credentials (Socket Mode) — see manifest.yaml for the app manifest
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...

# Slack user ID of the cctag owner (only this user may run `connect`/`disconnect`)
CCTAG_OWNER_USER_ID=U0XXXXXXX

# Path to the herdr CLI binary
CCTAG_HERDR_BIN=/opt/homebrew/bin/herdr

# Turn behavior
CCTAG_TURN_TIMEOUT_MS=1200000
CCTAG_POLL_INTERVAL_MS=1500
