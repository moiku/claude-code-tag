# --- Standalone mode (npm run dev / npm start) ---

# Slack app credentials (Socket Mode) — see manifest.yaml for the app manifest
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...

# Slack user ID of the cctag owner (only this user may run `connect`/`disconnect`)
CCTAG_OWNER_USER_ID=U0XXXXXXX

# Path to the herdr CLI binary
CCTAG_HERDR_BIN=/opt/homebrew/bin/herdr

# Turn behavior
CCTAG_TURN_TIMEOUT_MS=1200000
CCTAG_POLL_INTERVAL_MS=1500

# --- Spoke mode (npm run dev:spoke / start:spoke) ---
# Uses CCTAG_OWNER_USER_ID / CCTAG_HERDR_BIN / CCTAG_TURN_TIMEOUT_MS /
# CCTAG_POLL_INTERVAL_MS above instead of the Slack tokens. See README.md
# "Multi-user setups" for how to run a Hub and issue a token.
# CCTAG_HUB_URL=wss://your.domain.example
# CCTAG_SPOKE_TOKEN=...

# --- Hub mode (npm run dev:hub / start:hub) ---
# Uses SLACK_BOT_TOKEN / SLACK_APP_TOKEN above; ignores the rest.
# CCTAG_HUB_PORT=8765
